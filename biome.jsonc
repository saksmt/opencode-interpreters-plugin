{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "extends": ["./biome-all.jsonc"],
  "files": {
    "includes": [
      "src/**/*.ts",
      "tests/**/*.ts",
      "script/**/*.ts",
      "package.json",
      "tsconfig.json",
      "biome.jsonc"
    ]
  },
  "overrides": [
    {
      "includes": ["tests/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noMagicNumbers": "off",
            "useFilenamingConvention": "off"
          },
          "complexity": {
            "noExcessiveLinesPerFunction": {
              "level": "warn",
              "options": {
                "maxLines": 200
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/utils.ts"],
      "linter": {
        "rules": {
          "nursery": {
            "noExcessiveLinesPerFile": {
              "level": "error",
              "options": {
                // removing the temptation to grow utils...
                "maxLines": 100
              }
            }
          }
        }
      }
    }
  ],
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "attributePosition": "auto",
    "bracketSameLine": false,
    "bracketSpacing": true,
    "trailingNewline": true,
    "lineEnding": "lf",
    "lineWidth": 110
  },
  "linter": {
    "enabled": true,
    "domains": {
      "types": "all"
    },
    "rules": {
      "correctness": {
        "noNodejsModules": "off",
        "noUnresolvedImports": "off",
        "useQwikClasslist": "off",
        "noQwikUseVisibleTask": "off",
        "useQwikMethodUsage": "off",
        "useQwikValidLexicalScope": "off",
        "useImportExtensions": "off"
      },
      "style": {
        "noParameterProperties": "off",
        "noInferrableTypes": "off",
        "noUselessElse": "off",
        "useNamingConvention": {
          "level": "error",
          "options": {
            "strictCase": false
          }
        },
        // good one, but breaks top-to-bottom reading where it was otherwise possible
        "useExportsLast": "off"
      },
      "performance": {
        "noNamespaceImport": "off",
        // very useful feature for making facades
        "noBarrelFile": "off"
      },
      "suspicious": {
        "noImportCycles": {
          "level": "error",
          "options": {
            "ignoreTypes": true
          }
        }
      },
      "security": {
        // false positive most of the time
        "noSecrets": "off"
      },
      "complexity": {
        "noExcessiveLinesPerFunction": {
          "level": "error",
          "options": {
            "maxLines": 75
          }
        },
        "useMaxParams": {
          "level": "error",
          "options": {
            "max": 5
          }
        }
      },
      "nursery": {
        "noExcessiveLinesPerFile": {
          "level": "error",
          "options": {
            "maxLines": 350
          }
        }
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "indentWidth": 2
    }
  }
}
